    <System>
      <identifier>Mumbai_India</identifier>
      <description>Weather sensor located in Mumbai, India</description>
      <location>
        <gml:Point srsName="EPSG:4326">
          <gml:coordinates>72.8777,19.0760</gml:coordinates>
        </gml:Point>
      </location>
      <outputs>
        <OutputList>
          <output name="temperature" unit="Celsius"/>
          <output name="humidity" unit="%"/>
          <output name="wind_speed" unit="kph"/>
          <output name="pressure" unit="mb"/>
